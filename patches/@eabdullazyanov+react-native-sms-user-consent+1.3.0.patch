+            mainHandler.removeCallbacks(pendingSubscribeRunnable);
+            pendingSubscribeRunnable = null;
+        }
+        if (pendingStartPromise != null) {
+            pendingStartPromise.reject("E_SMS_USER_CONSENT_SUPERSEDED", "New listener start superseded previous");
+            pendingStartPromise = null;
         }
+        pendingStartPromise = promise;
+        pendingSubscribeRunnable = new Runnable() {
+            @Override
+            public void run() {
+                pendingSubscribeRunnable = null;
+                Promise p = pendingStartPromise;
+                pendingStartPromise = null;
+                if (p == null) {
+                    return;
+                }
+                try {
+                    subscribe();
+                    p.resolve(null);
+                } catch (RNSmsUserConsentException e) {
+                    p.reject(e.code, e.getMessage());
