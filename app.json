{
  "expo": {
    "name": "Ginit",
    "slug": "ginit-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ginitapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "compileSdkVersion": 35,
      "targetSdkVersion": 35,
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/android_icon_foreground.png",
        "monochromeImage": "./assets/images/android_icon_monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "채팅에 보낼 사진을 선택하기 위해 사진 라이브러리에 접근합니다.",
          "cameraPermission": "채팅에 보낼 사진을 촬영하기 위해 카메라에 접근합니다."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "지닛이 주변 모임을 보여 주기 위해 현재 위치를 사용합니다.",
          "locationAlwaysAndWhenInUsePermission": "지닛이 주변 모임을 보여 주기 위해 현재 위치를 사용합니다."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF",
          "android": {
            "backgroundColor": "#FFFFFF",
            "dark": {
              "backgroundColor": "#FFFFFF"
            }
          },
          "dark": {
            "image": "./assets/images/icon.png",
            "backgroundColor": "#0f172a"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          }
        }
      ],
      "./plugins/withAndroidGmsResourceFix.js"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
