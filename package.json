{
  "name": "ginit-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:clean": "expo start --clear",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "android:reverse": "adb reverse tcp:8081 tcp:8081",
    "android:logcat": "adb logcat -d -t 400 '*:S' 'ReactNativeJS:I' 'ReactNative:V' 'AndroidRuntime:E' | tail -120",
    "android:verify": "bash ./scripts/android-dev-verify.sh",
    "android:icons:png": "bash ./scripts/android-mipmap-webp-to-png.sh",
    "android:prebuild:icons": "expo prebuild --platform android --no-install && bash ./scripts/android-mipmap-webp-to-png.sh",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "vitest run",
    "postinstall": "patch-package",
    "notion:init": "python3 scripts/notion_helper.py init-dashboard",
    "notion:init:force": "python3 scripts/notion_helper.py init-dashboard --force",
    "notion:log": "python3 scripts/notion_helper.py update-log",
    "migrate:profiles:firestore-to-supabase": "node ./scripts/migrate-firestore-profiles-to-supabase.mjs",
    "migrate:categories:firestore-to-supabase": "node ./scripts/migrate-firestore-categories-to-supabase.mjs",
    "print:categories-sql": "node ./scripts/print-firestore-categories-sql.mjs"
  },
  "dependencies": {
    "@eabdullazyanov/react-native-sms-user-consent": "^1.3.0",
    "@ebrimasamba/react-native-sms-retriever": "^2.1.0",
    "@expo/vector-icons": "^15.0.3",
    "@lovesworking/watermelondb-expo-plugin-sdk-52-plus": "^1.0.3",
    "@mj-studio/react-native-naver-map": "^2.8.0",
    "@notifee/react-native": "^9.1.8",
    "@nozbe/simdjson": "^3.9.4",
    "@nozbe/watermelondb": "^0.28.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/auth": "^24.0.0",
    "@react-native-firebase/messaging": "^24.0.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.103.3",
    "@tanstack/query-async-storage-persister": "^5.100.5",
    "@tanstack/react-query": "^5.100.5",
    "@tanstack/react-query-persist-client": "^5.100.5",
    "expo": "~54.0.33",
    "expo-background-fetch": "~14.0.9",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
