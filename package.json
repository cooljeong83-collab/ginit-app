    "@babel/core": "^7.20.0",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@types/react": "~19.1.10",
    "dotenv": "^17.4.2",
    "eas-cli": "^18.9.1",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "firebase-admin": "^10.1.0",
    "patch-package": "^8.0.0",
    "typescript": "~5.9.2",
    "vitest": "^4.1.5"
  },
  "private": true
