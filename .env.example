# ─────────────────────────────────────────────────────────────
# 이 프로젝트는 기본으로 `env/.env` 를 읽습니다 (app.config.ts → expo.extra).
# 루트 `.env` / EXPO_PUBLIC_* 는 선택 폴백입니다.
#
# 절대 앱 번들에 넣지 말 것: SUPABASE_SERVICE_ROLE_KEY, NAVER_MAP_CLIENT_SECRET
# (서버·Edge Function·CI에서만 사용)
# ─────────────────────────────────────────────────────────────

# --- env/.env 에서 쓰는 이름 (권장) ---
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# FIREBASE_API_KEY=
# FIREBASE_AUTH_DOMAIN=
# FIREBASE_PROJECT_ID=
# FIREBASE_STORAGE_BUCKET=
# FIREBASE_MESSAGING_SENDER_ID=
# FIREBASE_APP_ID=
# NAVER_MAP_CLIENT_ID=
# Google 로그인(@react-native-google-signin) — Android에서 idToken 검증용 **웹 클라이언트 ID** (OAuth 2.0 > 웹 애플리케이션)
# WEB_CLIENT_ID=
# Google Maps SDK (Android) — AndroidManifest의 `com.google.android.geo.API_KEY`로 주입됨
# GOOGLE_MAPS_ANDROID_API_KEY=
# PUBLIC_APP_ENV=
# PUBLIC_API_BASE_URL=

# ─────────────────────────────────────────────────────────────
# 아래 EXPO_PUBLIC_* 는 루트 .env 만 쓸 때용 (선택)
# ─────────────────────────────────────────────────────────────

# Supabase (https://supabase.com/dashboard → Project Settings → API)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# (또는 env/.env 에 SUPABASE_URL / SUPABASE_ANON_KEY 만 있어도 app.config 가 extra 로 넣습니다)

# ── 푸시: FCM(Android) + Expo Push 폴백(iOS·FCM 미전달 시) ──
# Expo Push 토큰 등록 — https://expo.dev 에서 프로젝트 연결 후 Project ID (UUID)
# EAS_PROJECT_ID=
# EXPO_PUBLIC_EAS_PROJECT_ID=
# (선택) 클라이언트에서 Expo Push API 호출 시 — expo.dev → Access Tokens
# EXPO_PUBLIC_EXPO_ACCESS_TOKEN=
# EXPO_ACCESS_TOKEN=
# Android: Firebase 콘솔에서 Android 앱 추가 → `env/google-services.json` 저장(이미 있으면 생략)
# iOS FCM: Firebase에 iOS 앱 추가 → `GoogleService-Info.plist` 를 `env/GoogleService-Info.plist` 로 두면 prebuild 시 연결
# APNs: Firebase 콘솔 → 프로젝트 설정 → 클라우드 메시징 → Apple 앱 푸시 인증서/키 등록
# Supabase Edge `fcm-push-send` 배포 후 대시보드 Secrets 에 전체 JSON 문자열:
#   FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# 로그인한 기기에서 `profiles.fcm_token` 저장(FcmMessagingBootstrap) + Firestore `userExpoPushTokens`(PushNotificationBootstrap)

# Naver Cloud Platform / Maps (콘솔에서 발급한 클라이언트 ID)
EXPO_PUBLIC_NAVER_MAP_CLIENT_ID=

# 네이버 Search API — 지역 검색(openapi) 전용. 헤더는 X-Naver-Client-Id / X-Naver-Client-Secret 만 사용
EXPO_PUBLIC_NAVER_SEARCH_CLIENT_ID=
EXPO_PUBLIC_NAVER_SEARCH_CLIENT_SECRET=

# NCP Maps Geocoding — 선택한 주소의 위·경도. 헤더는 X-NCP-APIGW-API-KEY-ID / X-NCP-APIGW-API-KEY (naverLocal*)
# Geocoding 미체크 시 401 errorCode 210 가능
# NAVER_LOCAL_CLIENT_ID=   (미설정 시 지도용 ID로 폴백)
NAVER_LOCAL_CLIENT_SECRET=

# 웹(Metro 웹)에서만: CORS 프록시 오리진. 예) https://cors-anywhere.herokuapp.com — 개발용, 서비스 약관·데모 활성화 확인
# EXPO_PUBLIC_NAVER_LOCAL_SEARCH_CORS_PROXY=

# NCP Application Maps API 오리진 (미설정 시 https://maps.apigw.ntruss.com — api.ncloud-docs.com application-maps-overview)
# EXPO_PUBLIC_NAVER_MAPS_API_ORIGIN=
# Geocoding URI path (미설정 시 /map-geocode/v2/geocode — NCP 문서와 동일). /map-geocoding/v2/search 는 404
# EXPO_PUBLIC_NAVER_MAPS_GEOCODE_PATH=
# (구명) EXPO_PUBLIC_NAVER_LOCAL_SEARCH_API_BASE=  → naverMapsApiOrigin 폴백으로만 읽음

# Firebase JS SDK (콘솔 → 프로젝트 설정). Android는 `env/google-services.json`과 병행 가능.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google 로그인 — Android idToken 검증용 웹 OAuth 클라이언트 ID (네이티브·웹 공통)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Google Maps SDK (Android) — AndroidManifest의 `com.google.android.geo.API_KEY`로 주입됨
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_API_KEY=
# Places API(New) — 레거시(지도 SDK 등). 모임 생성 장소 검색은 Kakao 로컬 API 사용
# EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=

# Kakao 로컬 API — 키워드 장소 검색(https://developers.kakao.com/docs/latest/ko/local/dev-guide#search-by-keyword)
# 카카오디벨로퍼스 > 내 애플리케이션 > 앱 키 > REST API 키
EXPO_PUBLIC_KAKAO_REST_API_KEY=

# ── Notion (로컬 스크립트 scripts/notion_helper.py) — env/.env 권장 ──
# 통합에서 발급한 Internal Integration Token
# NOTION_TOKEN=
# 대시보드·로그를 쌓을 데이터베이스 ID (URL의 ...?v= 앞 32자 UUID)
# NOTION_DATABASE_ID=

# KOBIS(영화진흥위원회) 오픈API — 일별 박스오피스(https://www.kobis.or.kr/kobisopenapi)
EXPO_PUBLIC_KOBIS_KEY=

# TMDB v3 — 박스오피스 제목으로 포스터 검색(https://www.themoviedb.org/settings/api)
EXPO_PUBLIC_TMDB_API_KEY=

# 서버·CI 전용(모바일 앱 번들에 넣지 말 것)
# SUPABASE_SERVICE_ROLE_KEY=
#
# Firestore를 읽는 로컬 Node 스크립트(print:categories-sql, migrate:*:firestore-to-supabase)용
# GOOGLE_APPLICATION_CREDENTIALS=/절대/경로/firebase-adminsdk-xxxxx.json
# 또는 FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-adminsdk.json
# 또는 FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
